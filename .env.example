# =========================================================
# PLATON — PUBLIC SUPABASE CONFIGURATION
# These values are exposed to the browser.
# =========================================================

NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"


# =========================================================
# PLATON — PRIVATE SUPABASE CONFIGURATION
# Server only. Never expose this value in the browser.
# =========================================================

SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"


# =========================================================
# TRON NETWORK
#
# Development:
# TRON_DEPOSIT_NETWORK="SHASTA"
#
# Production:
# TRON_DEPOSIT_NETWORK="MAINNET"
# =========================================================

TRON_DEPOSIT_NETWORK="SHASTA"


# =========================================================
# TRONGRID
# Server-only API key.
# =========================================================

TRONGRID_API_KEY="YOUR_TRONGRID_API_KEY"


# =========================================================
# TRON USDT CONTRACT
#
# Insert the correct USDT TRC20 contract address
# for the selected TRON network.
# =========================================================

TRON_USDT_CONTRACT="YOUR_TRON_USDT_CONTRACT_ADDRESS"


# =========================================================
# USER DEPOSIT ADDRESS DERIVATION
#
# Server only.
# Never commit the real mnemonic or password.
# =========================================================

TRON_DEPOSIT_MNEMONIC="YOUR_SECURE_TRON_DEPOSIT_MNEMONIC"
TRON_DEPOSIT_MNEMONIC_PASSWORD="YOUR_OPTIONAL_MNEMONIC_PASSWORD"


# =========================================================
# PLATON HOT WALLET
#
# Used for automatic USDT withdrawals.
# The private key must remain server-only.
# =========================================================

TRON_HOT_WALLET_ADDRESS="YOUR_PLATON_HOT_WALLET_ADDRESS"
TRON_HOT_WALLET_PRIVATE_KEY="YOUR_PLATON_HOT_WALLET_PRIVATE_KEY"


# =========================================================
# PLATON TREASURY
#
# Destination for automatic deposit sweeps.
# It may be the same address as TRON_HOT_WALLET_ADDRESS
# depending on the selected production architecture.
# =========================================================

TRON_TREASURY_ADDRESS="YOUR_PLATON_TREASURY_ADDRESS"


# =========================================================
# TEST RECIPIENT
#
# Local SHASTA testing only.
# Do not configure these variables in production.
# =========================================================

TRON_TEST_RECIPIENT_ADDRESS="YOUR_SHASTA_TEST_RECIPIENT_ADDRESS"
TRON_TEST_RECIPIENT_PRIVATE_KEY="YOUR_SHASTA_TEST_RECIPIENT_PRIVATE_KEY"


# =========================================================
# INTERNAL USDT CRON AUTHENTICATION
#
# Use a long cryptographically random secret.
# Server only.
# =========================================================

USDT_DEPOSIT_SCAN_SECRET="YOUR_LONG_RANDOM_USDT_CRON_SECRET"